--	trigger to reduce stock value automatically if a customer purchases a product, and throws error if it's going out of stock

delimiter ^^

create trigger t1
before insert on orders1
for each row
begin
    declare s int;

    select stock into s
    from Products1
    where proid = new.pid;

    if new.No_of_copies > s then
        signal sqlstate '45000'
        set message_text = 'Not enough stock';
    else
        update Products1
        set stock = stock - new.No_of_copies
        where proid = new.pid;
    end if;
end ^^

delimiter ;

/*
signal sqlstate '45000'
means	Stop the operation and raise a custom error.

set message_text = 'Not enough stock'
This sets the error message that will be shown to the user.
*/


