--	function to display total price collected in a specific year on a product

delimiter !!
create function f1(a varchar(50), b year)
returns varchar(60) 
deterministic
begin
	declare fl1 float;
    declare fl2 float;
	Select coalesce((sum(price*no_of_copies)),0) ,
    coalesce(avg(price*no_of_copies),0) into fl1, fl2
    from orders1 as o join products1 as p
    on o.pid = p.proid
    where p.pname = a and year(o.order_date) = b;
    return concat('Total -> ',fl1,' Average -> ', fl2, ' in ', b , ' year.');
end !!
delimiter ;

	
--	Return customer names who ordered a product using a function

delimiter ##
create function f2(a varchar(40))
returns varchar(1000)
reads sql data
begin
	declare s1 varchar(1000);	--	declaring a variable name
	select coalesce(group_concat(cname),'No customers') into s1 
    from orders1 as o join customers1 as c
    on o.cid = c.cid
    join products1 as p
    on o.pid = p.proid
    where p.pname = a;
    
    return s1;
end ##
delimiter ;
